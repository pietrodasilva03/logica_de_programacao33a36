programa {
  funcao inicio() {
    inteiro  distinto1 , distinto2

    escreva("Digite o primeiro distinto:")
    leia(distinto1)

    escreva("digite o segundo distinto:")
    leia(distinto2)

    se(distinto1 > distinto2){
    escreva("o > distinto é")
    }senao se (distinto1 == distinto2){
    escreva("distinto 1 é igual a distinto 2")
    }senao {
   escreva("o distinto maior é")
    }








  }
}
