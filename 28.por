programa {
  funcao inicio() {
  inteiro anoAtual , anoNascimento

  escreva("ano atual :")
  leia(anoAtual)

  escreva("Digite o ano que você nasceu:")
  leia(anoNascimento)

  se(anoAtual - anoNascimento >= 16){
  escreva("Pode votar.")
  }senao{
  escreva("Não pode votar.")
  }

    
   


    
   


   

   

    
  






























  }
}
  

